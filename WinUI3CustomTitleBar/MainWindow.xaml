<Window
    x:Class="WinUI3CustomTitleBar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48">
            <Grid.ColumnDefinitions>
                <!-- Space reserved for system left chrome (e.g. restore button when snapped) -->
                <ColumnDefinition x:Name="LeftPaddingColumn" Width="0" />
                <!-- Title text — fills remaining space and acts as drag region -->
                <ColumnDefinition Width="*" />
                <!-- Expand/Collapse toggle button -->
                <ColumnDefinition Width="Auto" />
                <!-- Space reserved for system right buttons (minimize / maximize / close) -->
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Margin="12,0"
                Text="My App"
                Style="{StaticResource CaptionTextBlockStyle}" />

            <Button
                x:Name="ExpandCollapseButton"
                Grid.Column="2"
                Width="46"
                Height="32"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                ToolTipService.ToolTip="Expand / Collapse"
                Click="ExpandCollapseButton_Click">
                <FontIcon x:Name="BtnIcon" FontSize="12" Glyph="&#xE70E;" />
            </Button>
        </Grid>

        <!-- Page Content -->
        <TextBlock
            x:Name="PageContent"
            Grid.Row="1"
            Margin="16"
            Text="Page content goes here." />
    </Grid>
</Window>
