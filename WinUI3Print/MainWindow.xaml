<Window
    x:Class="WinUI3Print.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">
    <Grid>
        <muxc:TabView
            x:Name="MainTabView"
            AddTabButtonClick="MainTabView_AddTabButtonClick"
            TabCloseRequested="MainTabView_TabCloseRequested">
            <muxc:TabView.TabStripHeader>
                <ToggleButton x:Name="PinToggleButton" Click="PinToggleButton_Click" ToolTipService.ToolTip="Toggle always on top">
                    <FontIcon Glyph="&#xE840;" />
                </ToggleButton>
            </muxc:TabView.TabStripHeader>

            <muxc:TabView.TabItems>
                <muxc:TabViewItem Header="Project Brief - R..." IsClosable="True">
                    <TextBlock Margin="12" Text="Project Brief placeholder content" />
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="New Mail" IsClosable="True">
                    <TextBlock Margin="12" Text="New Mail placeholder content" />
                </muxc:TabViewItem>
            </muxc:TabView.TabItems>

            <muxc:TabView.TabStripFooter>
                <Grid x:Name="CustomDragRegion" MinWidth="188" Background="Transparent" />
            </muxc:TabView.TabStripFooter>
        </muxc:TabView>
    </Grid>
</Window>
